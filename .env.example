# ── Entorno ────────────────────────────────────────────────────────────────
# development | production. En production se aplican validaciones estrictas.
ENVIRONMENT=development

# ── Seguridad ──────────────────────────────────────────────────────────────
# OBLIGATORIO en producción: clave larga y aleatoria (>= 32 caracteres).
# Genera una con:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# En producción la app NO arranca si esto queda con el valor por defecto.
SECRET_KEY=change-this-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Base de datos ──────────────────────────────────────────────────────────
# SQLite sirve para desarrollo. En producción usa PostgreSQL, por ejemplo:
# DATABASE_URL=postgresql+psycopg://usuario:password@host:5432/moneyfast
DATABASE_URL=sqlite:///./moneyfast.db

# ── CORS ───────────────────────────────────────────────────────────────────
# Orígenes permitidos, separados por coma (dominios reales de la web en prod).
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:5173

# ── SMTP (recuperación de contraseña) ──────────────────────────────────────
# Si se deja vacío en desarrollo, el código se imprime en consola.
# En producción configúralo para enviar correos reales.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@moneyfast.com
SMTP_FROM_NAME=MoneyFast

# ── PayPal (suscripciones) ─────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox
